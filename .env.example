# Copy to .env and fill in values

# ---------------------------------------------------------------------------
# Supabase — ONE project for everything
# ---------------------------------------------------------------------------
# Use the SAME project for auth (auth.users), profiles, facility_tips, community_notes,
# facility_updates, and all
# migrations. Copy BOTH values from that project: Dashboard → Settings →
# API Keys (anon / public / publishable key + Project URL).
#
# Do not mix URL from project A with anon key from project B.
#
# After pointing here, configure Auth on that same project:
#   Authentication → URL Configuration
#     - Site URL: e.g. http://localhost:3000 (dev) or your production origin
#     - Redirect URLs: include http://localhost:3000/auth/callback and your
#       production https://YOUR_DOMAIN/auth/callback (needed for email + OAuth)
#
# Run SQL migrations in that project’s SQL Editor (or supabase link + db push):
#   supabase/migrations/*.sql — profiles, facility_tips, community_notes, facility_updates,
#   confirmations, etc.
#
# Note: Users in a different Supabase project are not migrated automatically;
# they would need to sign up again on this project (or you export/import via
# Supabase support / manual migration).
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Maps / geocoding
NEXT_PUBLIC_MAPBOX_TOKEN=""
MAPBOX_SECRET_TOKEN=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ---------------------------------------------------------------------------
# AI map query (NL → SQL → DuckDB) — /api/ai-map-query; requires signed-in user
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=""
# Optional override (default: gpt-4o-mini)
# AI_MAP_QUERY_MODEL="gpt-4o-mini"
# Set to 1 to include generated SQL in API responses (browser console logs it). Off in production unless you need it.
# AI_MAP_QUERY_LOG_SQL=1
# Optional: build data/zcta_centroids.csv (see data/zcta_centroids.README.md) for ZIP/ZCTA → nearest facility in AI SQL.

# ---------------------------------------------------------------------------
# Boundary GeoJSON (PWS + electric lookups)
# ---------------------------------------------------------------------------
# Production / Vercel: public HTTPS base for per-state files (no trailing slash).
# Objects must live at: {BOUNDARIES_BASE_URL}/cws-boundaries/by-state/CA.geojson
# (same paths as under ./data/ but without the leading "data/").
# Typical setup: Cloudflare R2 bucket → Settings → Public access → R2.dev subdomain,
# upload with: npm run upload:boundaries-r2 (see script; needs R2_* env in .env only locally).
# If unset, the app reads from ./data/... (local dev). Those boundary folders are
# gitignored — populate locally or rely on R2 in production (see data/README.md).
# ---------------------------------------------------------------------------
# BOUNDARIES_BASE_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# Upload script only (do not commit real values). Create R2 API token with Object Read & Write.
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET=""

# Optional: confirm_data_centers_google.mjs — Google Custom Search JSON API + Programmable Search Engine (cx)
# GOOGLE_CUSTOM_SEARCH_API_KEY=""
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=""
